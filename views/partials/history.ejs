<% histories.forEach(function(item) { %>
  <div class="timeLine-box">
    <div class="timeLine-line"></div>
    <div class="timeLine-dot"><i class="ico <%= item.iconClass %>"></i></div>
  </div>

  <div class="div-history <%= item.historyClass %>">
    <h2 class="history-yymm"><%= item.period %></h2>
    <article class="hidden_div history-content active">
      <div class="detail">
        <h3 class="title">
          경력 정보 & 주요 업무
        </h3>
        <p><%= item.companyLine %></p>
        <p><%= item.roleLine %></p>
        <p class="sub-title">수행업무</p>
        <% item.duties.forEach(function(text) { %>
          <p><%= text %></p>
        <% }); %>
        <!-- <p class="btn-popup" data-pop="">전체 프로젝트 상세 <i class="ico ico-popup"></i></p> -->
      </div>
    </article>
    <% if (item.showSlide) { %>
    <div class="swiper div-accodiant">
      <div class="swiper-wrapper">
        <%- include(item.slidePartial) %>
      </div>
      <% if (item.showControls) { %>
        <!-- Add Pagination -->
        <div class="swiper-fraction"></div>
        <!-- Add Arrows -->
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
      <% } %>
    </div>
    <% } %>
  </div>

  <% if (item.bgRingClass) { %>
    <div class="bg-ring <%= item.bgRingClass %>"></div>
  <% } %>
<% }); %>

